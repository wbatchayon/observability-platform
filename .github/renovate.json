{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    "helpers:pinGitHubActionDigests"
  ],
  "timezone": "Europe/Paris",
  "schedule": ["before 6am on monday"],
  "labels": ["dependencies"],
  "prConcurrentLimit": 5,
  "terraform": {
    "enabled": true
  },
  "helm-values": {
    "enabled": true
  },
  "flux": {
    "enabled": true
  },
  "packageRules": [
    {
      "description": "Auto-merge des mises à jour mineures/patch sûres",
      "matchUpdateTypes": ["minor", "patch"],
      "matchDepTypes": ["helm", "github-actions"],
      "automerge": true
    },
    {
      "description": "Mises à jour majeures : revue humaine obligatoire",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "addLabels": ["breaking-change"]
    },
    {
      "description": "Regrouper les composants de la stack Grafana",
      "matchPackageNames": ["loki", "mimir", "tempo", "grafana"],
      "groupName": "grafana-stack"
    }
  ],
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "automerge": false
  }
}
