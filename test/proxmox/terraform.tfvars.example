# Copier en terraform.tfvars et adapter à ton Proxmox.
proxmox_endpoint = "https://100.127.112.10:8006/"
proxmox_insecure = true
proxmox_node     = "pve" # nom de ton nœud Proxmox

datastore_id          = "local-lvm" # disques des VMs
snippets_datastore_id = "local"     # doit supporter les snippets (cloud-init)
bridge                = "vmbr0"

# Template cloud-init Ubuntu 22.04 (VM ID à créer au préalable, voir README)
template_id = 9000

gateway        = "100.127.112.1"
netmask        = 24
ssh_user       = "ubuntu"
ssh_public_key = "ssh-ed25519 AAAA... ta_cle_publique"

# Cluster de test (1 control-plane + 2 workers). Ajuste IP/ressources selon ton réseau.
nodes = [
  { name = "obs-test-cp1", vm_id = 9001, ip = "100.127.112.21", cores = 2, memory = 4096, disk = 40, role = "control-plane" },
  { name = "obs-test-w1", vm_id = 9002, ip = "100.127.112.22", cores = 4, memory = 8192, disk = 60, role = "worker" },
  { name = "obs-test-w2", vm_id = 9003, ip = "100.127.112.23", cores = 4, memory = 8192, disk = 60, role = "worker" },
]
